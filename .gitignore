# ============================================================
# .gitignore — Python + IntelliJ IDEA + Jupyter
# ============================================================

# --- IntelliJ IDEA ---
.idea/

# --- Python bytecode ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --- Jupyter / Colab ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Dataset (dati potenzialmente pesanti — non versionare) ---
data/

# --- Ambienti virtuali ---
.venv/
venv/
env/
*.egg-info/
dist/
build/

# --- OS ---
.DS_Store
Thumbs.db
